<!-- res/drawable/focus_selector_visible.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state - make it VERY obvious -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Outer glow -->
            <item>
                <shape>
                    <solid android:color="#00FFFFFF" />
                    <stroke 
                        android:width="4dp" 
                        android:color="#FF00FF" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- Inner highlight -->
            <item android:top="2dp" android:bottom="2dp" 
                  android:left="2dp" android:right="2dp">
                <shape>
                    <solid android:color="#20FF00FF" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed state (for touch/click) -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#40FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="#00FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>